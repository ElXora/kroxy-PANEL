<aside class="sidebar">
  <div class="sidebar-logo">
    <span class="logo-bracket">[</span>KROXY<span class="logo-bracket">]</span>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">MAIN</div>
    <a href="/dashboard" class="nav-item <%= pageTitle && pageTitle.includes('Dashboard') ? 'active' : '' %>">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/servers" class="nav-item <%= pageTitle && pageTitle.includes('Server') ? 'active' : '' %>">
      <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="5" rx="1"/><rect x="2" y="10" width="20" height="5" rx="1"/><rect x="2" y="17" width="20" height="5" rx="1"/><circle cx="18" cy="5.5" r="1" fill="currentColor"/><circle cx="18" cy="12.5" r="1" fill="currentColor"/><circle cx="18" cy="19.5" r="1" fill="currentColor"/></svg>
      Servers
    </a>

    <div class="nav-section-label">ACCOUNT</div>
    <div class="nav-item kxy-nav">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5-2.5 2-2.5 3.5 1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5"/></svg>
      <span id="sidebar-kxy"><%= user ? (user.kxy || 0) : 0 %></span>&nbsp;KXY
    </div>

    <% if (user && user.isAdmin) { %>
    <div class="nav-section-label">ADMIN</div>
    <a href="/admin" class="nav-item <%= pageTitle && pageTitle.includes('Admin') && !pageTitle.includes('Node') ? 'active' : '' %>">
      <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Admin Panel
    </a>
    <a href="/admin/nodes" class="nav-item <%= pageTitle && pageTitle.includes('Node') ? 'active' : '' %>">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><line x1="12" y1="8" x2="5" y2="16"/><line x1="12" y1="8" x2="19" y2="16"/></svg>
      Nodes
    </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="user-avatar"><%= user ? user.username[0].toUpperCase() : '?' %></div>
      <div class="user-info">
        <span class="user-name"><%= user ? user.username : '' %></span>
        <span class="user-role"><%= user && user.isAdmin ? 'Administrator' : 'User' %></span>
      </div>
    </div>
    <a href="/logout" class="logout-btn" title="Logout">
      <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
    </a>
  </div>
</aside>
