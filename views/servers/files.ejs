<div class="files-page">
  <!-- Server sub-nav -->
  <div class="server-subnav">
    <a href="/servers/<%= server._id %>" class="subnav-item">CONSOLE</a>
    <a href="/servers/<%= server._id %>/files" class="subnav-item active">FILES</a>
  </div>

  <!-- Breadcrumb -->
  <div class="files-breadcrumb">
    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <% breadcrumbs.forEach((b, i) => { %>
      <% if (i > 0) { %><span class="bc-sep">/</span><% } %>
      <a href="/servers/<%= server._id %>/files?path=<%= b.path %>" class="bc-item <%= i === breadcrumbs.length - 1 ? 'bc-current' : '' %>"><%= b.name %></a>
    <% }) %>
  </div>

  <!-- Toolbar -->
  <div class="files-toolbar">
    <div class="files-toolbar-left">
      <button class="btn btn-primary btn-sm" onclick="showUpload()">
        <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
        UPLOAD
      </button>
      <button class="btn btn-ghost btn-sm" onclick="showNewFolder()">
        <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
        NEW FOLDER
      </button>
    </div>
    <div class="files-toolbar-right">
      <span class="files-count"><%= entries.length %> item<%= entries.length !== 1 ? 's' : '' %></span>
    </div>
  </div>

  <!-- Upload area (hidden) -->
  <div class="upload-area" id="uploadArea" style="display:none">
    <form id="uploadForm" enctype="multipart/form-data">
      <input type="hidden" name="path" value="<%= currentPath %>" />
      <input type="file" id="fileInput" multiple onchange="handleUpload()" style="display:none" />
      <div class="upload-drop" onclick="document.getElementById('fileInput').click()">
        <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
        <p>Click to select files or drag & drop here</p>
      </div>
      <div id="uploadProgress" style="display:none" class="upload-progress-list"></div>
    </form>
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('uploadArea').style.display='none'" style="margin-top:8px">CANCEL</button>
  </div>

  <!-- New folder input (hidden) -->
  <div class="newfolder-bar" id="newFolderBar" style="display:none">
    <input type="text" id="folderName" class="form-input" placeholder="folder-name" />
    <button class="btn btn-primary btn-sm" onclick="createFolder()">CREATE</button>
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('newFolderBar').style.display='none'">CANCEL</button>
  </div>

  <!-- File table -->
  <div class="panel">
    <div class="panel-body" style="padding:0">
      <% if (error) { %>
        <div class="flash flash-error" style="margin:16px"><%= error %></div>
      <% } %>
      <% if (entries.length === 0) { %>
        <div class="empty-state"><p>This folder is empty.</p></div>
      <% } else { %>
      <table class="data-table files-table">
        <thead>
          <tr><th width="40"></th><th>NAME</th><th>SIZE</th><th>ACTIONS</th></tr>
        </thead>
        <tbody>
          <% entries.forEach(entry => { %>
          <tr class="file-row" data-path="<%= entry.path %>" data-isdir="<%= entry.isDir %>">
            <td class="file-icon-cell">
              <% if (entry.isDir) { %>
                <svg class="icon-folder" viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
              <% } else { %>
                <svg class="icon-file" viewBox="0 0 24 24"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
              <% } %>
            </td>
            <td>
              <% if (entry.isDir) { %>
                <a href="/servers/<%= server._id %>/files?path=<%= entry.path %>" class="file-link dir-link"><%= entry.name %></a>
              <% } else { %>
                <span class="file-link"><%= entry.name %></span>
              <% } %>
            </td>
            <td class="file-size">
              <% if (!entry.isDir) { %>
                <%= entry.size < 1024 ? entry.size + 'B' : entry.size < 1048576 ? (entry.size/1024).toFixed(1)+'KB' : (entry.size/1048576).toFixed(1)+'MB' %>
              <% } else { %>
                <span class="muted-text">—</span>
              <% } %>
            </td>
            <td class="actions-cell">
              <% if (!entry.isDir) { %>
                <a href="/servers/<%= server._id %>/files/edit?path=<%= entry.path %>" class="btn btn-sm btn-ghost">EDIT</a>
                <a href="/servers/<%= server._id %>/files/download?path=<%= entry.path %>" class="btn btn-sm btn-ghost">DL</a>
              <% } %>
              <button class="btn btn-sm btn-danger" onclick="deleteEntry('<%= entry.path %>', '<%= entry.name %>', <%= entry.isDir %>)">DEL</button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<script>
const SERVER_ID   = '<%= server._id %>';
const CURRENT_PATH = '<%= currentPath %>';

function showUpload()    { document.getElementById('uploadArea').style.display = 'block'; }
function showNewFolder() { document.getElementById('newFolderBar').style.display = 'flex'; document.getElementById('folderName').focus(); }

async function createFolder() {
  const name = document.getElementById('folderName').value.trim();
  if (!name) return;
  const res  = await fetch(`/servers/${SERVER_ID}/files/mkdir`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: CURRENT_PATH, name }),
  });
  const data = await res.json();
  if (data.success) location.reload();
  else alert('Error: ' + data.message);
}

async function deleteEntry(path, name, isDir) {
  if (!confirm(`Delete "${name}"${isDir ? ' and all its contents' : ''}?`)) return;
  const res  = await fetch(`/servers/${SERVER_ID}/files/delete`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path }),
  });
  const data = await res.json();
  if (data.success) location.reload();
  else alert('Error: ' + data.message);
}

async function handleUpload() {
  const files = document.getElementById('fileInput').files;
  if (!files.length) return;
  const progressList = document.getElementById('uploadProgress');
  progressList.style.display = 'block';
  progressList.innerHTML = '';

  for (const file of files) {
    const item = document.createElement('div');
    item.className = 'upload-item';
    item.textContent = `Uploading ${file.name}...`;
    progressList.appendChild(item);

    const formData = new FormData();
    formData.append('path', CURRENT_PATH);
    formData.append('file', file);

    try {
      const res  = await fetch(`/servers/${SERVER_ID}/files/upload`, { method: 'POST', body: formData });
      const data = await res.json();
      item.textContent = data.success ? `✓ ${file.name}` : `✗ ${file.name}: ${data.message}`;
      item.className   = 'upload-item ' + (data.success ? 'upload-ok' : 'upload-fail');
    } catch(e) {
      item.textContent = `✗ ${file.name}: upload failed`;
      item.className = 'upload-item upload-fail';
    }
  }
  setTimeout(() => location.reload(), 1200);
}

// Drag and drop
const dropZone = document.querySelector('.upload-drop');
if (dropZone) {
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault(); dropZone.classList.remove('drag-over');
    const dt = e.dataTransfer;
    const fileInput = document.getElementById('fileInput');
    fileInput.files = dt.files;
    handleUpload();
  });
}
</script>
