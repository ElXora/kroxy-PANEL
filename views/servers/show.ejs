<% if (server.status === 'installing') { %>
<div class="install-overlay" id="installOverlay">
  <div class="install-spinner"></div>
  <div class="install-title">INSTALLING SERVER</div>
  <div class="install-sub">Setting up your Minecraft server. This usually takes 1–3 minutes.</div>

  <div class="install-steps">
    <div class="install-step step-done" id="istep-1">
      <svg class="install-step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      Creating server directory
    </div>
    <div class="install-step step-active" id="istep-2">
      <svg class="install-step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
      Pulling Docker image
    </div>
    <div class="install-step" id="istep-3">
      <svg class="install-step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="5" rx="1"/></svg>
      Creating container
    </div>
    <div class="install-step" id="istep-4">
      <svg class="install-step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
      Starting server
    </div>
  </div>

  <div class="install-bar-wrap">
    <div class="install-bar" id="installBar" style="width:25%"></div>
  </div>
  <div class="install-progress-pct" id="installPct">Pulling image...</div>

  <% if (server.installError) { %>
  <div class="flash flash-error" style="margin-top:8px">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Install Error: <%= server.installError %>
    <form method="POST" action="/servers/<%= server._id %>/reinstall" style="display:inline;margin-left:10px">
      <button type="submit" class="btn btn-sm btn-primary">RETRY</button>
    </form>
  </div>
  <% } %>
</div>

<script>
// Poll install status every 3s
let installPct = 25;
const steps = ['istep-1','istep-2','istep-3','istep-4'];
let stepIdx = 1;

const stepMsgs = ['Creating directory...', 'Pulling Docker image...', 'Creating container...', 'Starting server...'];

async function pollInstall() {
  try {
    const res  = await fetch('/api/servers/<%= server._id %>/install-status');
    const data = await res.json();

    if (data.ready && data.status !== 'installing') {
      // Done — reload page
      document.getElementById('installPct').textContent = 'Done! Loading...';
      document.getElementById('installBar').style.width = '100%';
      setTimeout(() => location.reload(), 800);
      return;
    }

    if (data.status === 'error') {
      document.getElementById('installPct').textContent = 'Error: ' + (data.error || 'Unknown error');
      document.getElementById('installPct').style.color = 'var(--red)';
      steps.forEach(s => document.getElementById(s).classList.remove('step-active'));
      return;
    }

    // Animate progress
    installPct = Math.min(installPct + 8, 90);
    document.getElementById('installBar').style.width = installPct + '%';

    // Step animation
    if (installPct > 30 && stepIdx < 2) { activateStep(2); stepIdx = 2; }
    if (installPct > 55 && stepIdx < 3) { activateStep(3); stepIdx = 3; }
    if (installPct > 75 && stepIdx < 4) { activateStep(4); stepIdx = 4; }

    document.getElementById('installPct').textContent = stepMsgs[Math.min(stepIdx - 1, 3)];

    setTimeout(pollInstall, 3000);
  } catch(e) {
    setTimeout(pollInstall, 5000);
  }
}

function activateStep(n) {
  for (let i = 1; i < n; i++) {
    const el = document.getElementById('istep-' + i);
    if (el) { el.classList.remove('step-active'); el.classList.add('step-done'); }
  }
  const active = document.getElementById('istep-' + n);
  if (active) active.classList.add('step-active');
}

pollInstall();
</script>
<% } else { %>
<div class="server-manage-wrap">

  <!-- Server header -->
  <div class="server-header-card">
    <div class="server-header-info">
      <div class="server-game-badge">MC</div>
      <div>
        <h2 class="server-title"><%= server.name %></h2>
        <p class="server-meta">
          Port <code><%= server.port %></code>
          · <code><%= server.ram %>MB</code> RAM
          · v<%= server.version %>
          <% if (node) { %>
            · <svg viewBox="0 0 24 24" style="width:12px;height:12px;display:inline;vertical-align:middle;stroke:currentColor;fill:none"><circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><line x1="12" y1="8" x2="5" y2="16"/><line x1="12" y1="8" x2="19" y2="16"/></svg>
            <strong><%= node.name %></strong> (<%= node.region %>)
          <% } %>
        </p>
      </div>
    </div>
    <div class="server-header-right">
      <span class="status-pill status-<%= server.status %>" id="statusPill">
        <span class="status-dot-lg status-<%= server.status %>" id="statusDot"></span>
        <span id="statusText"><%= server.status.toUpperCase() %></span>
      </span>
    </div>
  </div>

  <!-- Control buttons -->
  <div class="server-controls">
    <button class="btn btn-success" id="btnStart" onclick="serverAction('start')" <%= server.status==='running'?'disabled':'' %>>
      <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg> START
    </button>
    <button class="btn btn-warning" id="btnStop" onclick="serverAction('stop')" <%= server.status!=='running'?'disabled':'' %>>
      <svg viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> STOP
    </button>
    <button class="btn btn-ghost" id="btnRestart" onclick="serverAction('restart')" <%= server.status!=='running'?'disabled':'' %>>
      <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> RESTART
    </button>
    <button class="btn btn-danger" onclick="if(confirm('Kill process immediately?')) serverAction('kill')">
      <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> KILL
    </button>
    <form method="POST" action="/servers/<%= server._id %>/delete" style="margin-left:auto"
          onsubmit="return confirm('Permanently delete this server and all its data?')">
      <button type="submit" class="btn btn-danger">
        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/></svg> DELETE
      </button>
    </form>
  </div>

  <!-- Stats row -->
  <div class="stats-row stats-server">
    <div class="stat-card">
      <div class="stat-label">CPU USAGE</div>
      <div class="stat-value" id="statCpu">—</div>
      <div class="stat-bar"><div class="stat-bar-fill" id="cpuBar" style="width:0%"></div></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">MEMORY</div>
      <div class="stat-value" id="statMem">—</div>
      <div class="stat-bar"><div class="stat-bar-fill" id="memBar" style="width:0%"></div></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">STATUS</div>
      <div class="stat-value" id="statStatus"><%= server.status.toUpperCase() %></div>
    </div>
    <div class="stat-card addr-copy-card" onclick="copyAddr()" title="Click to copy">
      <div class="stat-label">ADDRESS</div>
      <div class="stat-value addr-val">
        <code id="serverAddr"><%= server.connectAddress || (node ? (node.connectIp || node.ip) + ':' + server.port : 'localhost:' + server.port) %></code>
        <svg viewBox="0 0 24 24" style="width:13px;opacity:.4"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="server-tabs">
    <button class="server-tab active" onclick="switchTab('console', this)">
      <svg viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> CONSOLE
    </button>
    <button class="server-tab" onclick="switchTab('files', this)">
      <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg> FILES
    </button>
    <button class="server-tab" onclick="switchTab('schedules', this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> SCHEDULES
    </button>
    <button class="server-tab" onclick="switchTab('subusers', this)">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg> SUB-USERS
    </button>
    <button class="server-tab" onclick="switchTab('startup', this)">
      <svg viewBox="0 0 24 24"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg> STARTUP
    </button>
    <button class="server-tab" onclick="switchTab('settings', this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg> SETTINGS
    </button>
  </div>

  <!-- CONSOLE TAB -->
  <div class="tab-content" id="tab-console">
    <div class="panel console-panel">
      <div class="panel-header">
        <h2 class="panel-title">CONSOLE</h2>
        <div style="display:flex;gap:10px;align-items:center">
          <span class="ws-status" id="wsStatus">● CONNECTING...</span>
          <button class="btn btn-sm btn-ghost" onclick="clearConsole()">CLEAR</button>
        </div>
      </div>
      <div class="console-output" id="consoleOutput">
        <div class="console-placeholder">Connecting to console...</div>
      </div>
      <div class="console-input-row">
        <span class="console-prompt">$</span>
        <input type="text" id="consoleInput" class="console-input" placeholder="Type a Minecraft command (e.g. say Hello)..." autocomplete="off" />
        <button class="btn btn-primary btn-sm" onclick="sendCmd()">SEND</button>
      </div>
    </div>
  </div>

  <!-- FILES TAB -->
  <div class="tab-content" id="tab-files" style="display:none">
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">FILE MANAGER</h2>
        <div style="display:flex;gap:8px">
          <button class="btn btn-primary btn-sm" onclick="showUploadModal()">
            <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/></svg> UPLOAD
          </button>
          <button class="btn btn-ghost btn-sm" onclick="showNewFolderModal()">
            <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg> NEW FOLDER
          </button>
          <button class="btn btn-ghost btn-sm" onclick="showNewFileModal()">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg> NEW FILE
          </button>
        </div>
      </div>
      <div class="panel-body" style="padding:0">
        <!-- Breadcrumb -->
        <div class="files-breadcrumb" id="fileBreadcrumb" style="padding:12px 20px;border-bottom:1px solid var(--border)">
          <svg viewBox="0 0 24 24" style="width:13px;height:13px"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          <span class="bc-item bc-current" onclick="loadFiles('/')" style="cursor:pointer">root</span>
        </div>
        <div id="filesList"></div>
        <div id="filesLoading" class="empty-state" style="padding:32px">
          <div class="spinner"></div><p>Loading files...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- SCHEDULES TAB -->
  <div class="tab-content" id="tab-schedules" style="display:none">
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">SCHEDULES</h2>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('newScheduleForm').style.display='block'">+ NEW</button>
      </div>
      <div class="panel-body">
        <!-- New schedule form -->
        <div id="newScheduleForm" style="display:none" class="schedule-form">
          <form method="POST" action="/servers/<%= server._id %>/schedules/create">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">NAME</label>
                <input type="text" name="name" class="form-input" placeholder="e.g. Nightly Restart" required />
              </div>
              <div class="form-group">
                <label class="form-label">ACTION</label>
                <select name="action" class="form-input form-select" onchange="togglePayload(this)">
                  <option value="command">Run Command</option>
                  <option value="restart">Restart Server</option>
                  <option value="stop">Stop Server</option>
                  <option value="start">Start Server</option>
                </select>
              </div>
              <div class="form-group" id="payloadGroup">
                <label class="form-label">COMMAND</label>
                <input type="text" name="payload" class="form-input" placeholder="say Server restarting..." />
              </div>
            </div>
            <h3 class="form-section-title" style="margin-bottom:10px">CRON SCHEDULE</h3>
            <div class="cron-row">
              <div class="form-group"><label class="form-label">MINUTE</label><input type="text" name="cronMinute" class="form-input" value="0" /></div>
              <div class="form-group"><label class="form-label">HOUR</label><input type="text" name="cronHour" class="form-input" value="0" /></div>
              <div class="form-group"><label class="form-label">DAY</label><input type="text" name="cronDay" class="form-input" value="*" /></div>
              <div class="form-group"><label class="form-label">MONTH</label><input type="text" name="cronMonth" class="form-input" value="*" /></div>
              <div class="form-group"><label class="form-label">WEEKDAY</label><input type="text" name="cronWeekday" class="form-input" value="*" /></div>
            </div>
            <p class="form-hint" style="margin-bottom:12px">Example: <code>0 4 * * *</code> = every day at 4:00 AM</p>
            <label class="toggle-label" style="margin-bottom:14px">
              <input type="checkbox" name="enabled" checked /><span class="toggle-switch"></span> ENABLED
            </label><br/>
            <div style="display:flex;gap:8px;margin-top:8px">
              <button type="submit" class="btn btn-primary">CREATE SCHEDULE</button>
              <button type="button" class="btn btn-ghost" onclick="document.getElementById('newScheduleForm').style.display='none'">CANCEL</button>
            </div>
          </form>
        </div>
        <!-- Schedules list -->
        <div id="schedulesList">Loading...</div>
      </div>
    </div>
  </div>

  <!-- SUB-USERS TAB -->
  <div class="tab-content" id="tab-subusers" style="display:none">
    <div class="panel">
      <div class="panel-header"><h2 class="panel-title">SUB-USERS</h2></div>
      <div class="panel-body">
        <p class="panel-desc">Give other users access to this server with specific permissions.</p>
        <div class="subuser-add-form">
          <input type="email" id="suEmail" class="form-input" placeholder="User's email address" style="flex:1" />
          <div class="subuser-perms">
            <% ['console','files','schedules','startup','settings'].forEach(p => { %>
            <label class="perm-check">
              <input type="checkbox" class="su-perm" value="<%= p %>" checked /> <%= p %>
            </label>
            <% }) %>
          </div>
          <button class="btn btn-primary" onclick="addSubUser()">ADD</button>
        </div>
        <div id="suResult" style="display:none;margin-top:10px"></div>
        <div id="subusersList" style="margin-top:20px">Loading...</div>
      </div>
    </div>
  </div>

  <!-- STARTUP TAB -->
  <div class="tab-content" id="tab-startup" style="display:none">
    <div class="panel">
      <div class="panel-header"><h2 class="panel-title">STARTUP VARIABLES</h2></div>
      <div class="panel-body">
        <form method="POST" action="/servers/<%= server._id %>/startup" id="startupForm">
          <div class="form-group">
            <label class="form-label">MINECRAFT VERSION</label>
            <select name="version" class="form-input form-select">
              <% ['LATEST','1.21.4','1.20.6','1.20.4','1.20.1','1.19.4','1.18.2','1.17.1','1.16.5','1.12.2','1.8.9'].forEach(v => { %>
              <option value="<%= v %>" <%= server.version===v?'selected':'' %>><%= v %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">SERVER TYPE</label>
            <select name="serverType" class="form-input form-select">
              <% ['VANILLA','PAPER','SPIGOT','FABRIC','FORGE','PURPUR'].forEach(t => { %>
              <option value="<%= t %>" <%= (server.serverType||'VANILLA')===t?'selected':'' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">MEMORY (MB)</label>
            <input type="number" name="ram" class="form-input" value="<%= server.ram %>" min="512" max="16384" />
          </div>
          <div class="form-group">
            <label class="form-label">JAVA FLAGS (advanced)</label>
            <input type="text" name="javaFlags" class="form-input" value="<%= server.javaFlags||'' %>" placeholder="-XX:+UseG1GC -XX:+ParallelRefProcEnabled" />
            <span class="form-hint">Extra JVM arguments. Leave blank for defaults.</span>
          </div>
          <div class="form-group">
            <label class="form-label">ONLINE MODE</label>
            <select name="onlineMode" class="form-input form-select">
              <option value="false" <%= !server.onlineMode?'selected':'' %>>FALSE (cracked/offline)</option>
              <option value="true"  <%= server.onlineMode?'selected':'' %>>TRUE (premium only)</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary">SAVE & REINSTALL</button>
          <p class="form-hint" style="margin-top:8px">Saving startup variables will recreate the Docker container. The server will be briefly offline.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- SETTINGS TAB -->
  <div class="tab-content" id="tab-settings" style="display:none">
    <div class="panel">
      <div class="panel-header"><h2 class="panel-title">SERVER SETTINGS</h2></div>
      <div class="panel-body">
        <form method="POST" action="/servers/<%= server._id %>/settings">
          <div class="form-group">
            <label class="form-label">SERVER NAME</label>
            <input type="text" name="name" class="form-input" value="<%= server.name %>" required maxlength="32" />
          </div>
          <div class="form-group">
            <label class="form-label">DESCRIPTION</label>
            <input type="text" name="description" class="form-input" value="<%= server.description||'' %>" placeholder="Optional description" />
          </div>
          <div class="form-group">
            <label class="form-label">ASSIGNED PORT</label>
            <input type="number" name="port" class="form-input" value="<%= server.port %>" min="1024" max="65535" />
          </div>
          <hr style="border-color:var(--border);margin:20px 0" />
          <h3 class="form-section-title" style="color:var(--red);margin-bottom:12px">DANGER ZONE</h3>
          <button type="submit" class="btn btn-primary">SAVE SETTINGS</button>
          &nbsp;
          <form method="POST" action="/servers/<%= server._id %>/reinstall" style="display:inline"
                onsubmit="return confirm('Reinstall the server? All files will be deleted.')">
            <button type="submit" class="btn btn-danger">REINSTALL</button>
          </form>
        </form>
      </div>
    </div>
  </div>

</div>

<!-- File edit modal -->
<div class="modal-overlay" id="fileEditModal" style="display:none" onclick="if(event.target===this)closeFileEdit()">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h3 class="modal-title" id="fileEditTitle">EDIT FILE</h3>
      <div style="display:flex;gap:8px;align-items:center">
        <span class="editor-status" id="fileEditStatus"></span>
        <button class="btn btn-primary btn-sm" onclick="saveFileEdit()">SAVE</button>
        <button class="modal-close" onclick="closeFileEdit()">×</button>
      </div>
    </div>
    <div class="modal-body" style="padding:0;display:flex">
      <div class="editor-line-numbers" id="editLineNums"></div>
      <textarea class="code-editor" id="fileEditArea" spellcheck="false"></textarea>
    </div>
  </div>
</div>

<!-- Upload modal -->
<div class="modal-overlay" id="uploadModal" style="display:none" onclick="if(event.target===this)closeUploadModal()">
  <div class="modal">
    <div class="modal-header"><h3 class="modal-title">UPLOAD FILES</h3><button class="modal-close" onclick="closeUploadModal()">×</button></div>
    <div class="modal-body">
      <div class="upload-drop" id="uploadDropZone" onclick="document.getElementById('uploadInput').click()">
        <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
        <p>Click to select or drag & drop files here</p>
      </div>
      <input type="file" id="uploadInput" multiple style="display:none" onchange="handleUpload()" />
      <div id="uploadProgress" style="margin-top:10px"></div>
    </div>
  </div>
</div>

<!-- New folder modal -->
<div class="modal-overlay" id="newFolderModal" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header"><h3 class="modal-title">NEW FOLDER</h3><button class="modal-close" onclick="document.getElementById('newFolderModal').style.display='none'">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">FOLDER NAME</label><input type="text" id="newFolderName" class="form-input" placeholder="my-folder" /></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="document.getElementById('newFolderModal').style.display='none'">CANCEL</button>
      <button class="btn btn-primary" onclick="createFolder()">CREATE</button>
    </div>
  </div>
</div>

<!-- New file modal -->
<div class="modal-overlay" id="newFileModal" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header"><h3 class="modal-title">NEW FILE</h3><button class="modal-close" onclick="document.getElementById('newFileModal').style.display='none'">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">FILE NAME</label><input type="text" id="newFileName" class="form-input" placeholder="config.yml" /></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="document.getElementById('newFileModal').style.display='none'">CANCEL</button>
      <button class="btn btn-primary" onclick="createFile()">CREATE</button>
    </div>
  </div>
</div>

<script>
const SERVER_ID = '<%= server._id %>';
const WS_TOKEN  = '<%= wsToken || "" %>';

// ===== TAB SYSTEM =====
function switchTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.server-tab').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-' + name).style.display = 'block';
  btn.classList.add('active');
  if (name === 'files')     { loadFiles(currentPath); }
  if (name === 'schedules') { loadSchedules(); }
  if (name === 'subusers')  { loadSubUsers(); }
}

// ===== CONSOLE =====
let ws = null, firstLog = true;
const consoleOut = document.getElementById('consoleOutput');

function connectWs() {
  if (!WS_TOKEN) { updateWsStatus('NO TOKEN', false); return; }
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  ws = new WebSocket(`${proto}://${location.host}/ws/console?serverId=${SERVER_ID}&token=${WS_TOKEN}`);
  ws.onopen    = () => updateWsStatus('● CONNECTED', true);
  ws.onclose   = () => { updateWsStatus('● DISCONNECTED', false); setTimeout(connectWs, 4000); };
  ws.onerror   = () => updateWsStatus('● ERROR', false);
  ws.onmessage = (e) => {
    try {
      const msg = JSON.parse(e.data);
      if (msg.type === 'log')    appendLog(msg.data);
      if (msg.type === 'status') updateWsStatus('● CONNECTED', true);
      if (msg.type === 'error')  appendLog('[ERROR] ' + msg.message + '\n');
    } catch(ex) {}
  };
}

function updateWsStatus(text, ok) {
  const el = document.getElementById('wsStatus');
  if (el) { el.textContent = text; el.style.color = ok ? 'var(--green)' : 'var(--muted)'; }
}

function appendLog(text) {
  if (firstLog) { consoleOut.innerHTML = ''; firstLog = false; }
  const lines = text.split('\n');
  lines.forEach(line => {
    if (!line && lines[lines.length-1] === line) return;
    const el = document.createElement('div');
    el.className = 'console-line';
    // Color coding
    if (line.includes('[ERROR]') || line.includes('ERROR')) el.style.color = '#f87171';
    else if (line.includes('[WARN]') || line.includes('WARN')) el.style.color = '#facc15';
    else if (line.includes('[INFO]')) el.style.color = '#94a3b8';
    else el.style.color = '#d4d4d4';
    el.textContent = line;
    consoleOut.appendChild(el);
  });
  consoleOut.scrollTop = consoleOut.scrollHeight;
}

function clearConsole() { consoleOut.innerHTML = '<div class="console-placeholder">Console cleared.</div>'; firstLog = true; }

function sendCmd() {
  const input = document.getElementById('consoleInput');
  const cmd = input.value.trim();
  if (!cmd || !ws || ws.readyState !== 1) return;
  ws.send(JSON.stringify({ type: 'command', command: cmd }));
  input.value = '';
}
document.getElementById('consoleInput').addEventListener('keydown', e => { if (e.key === 'Enter') sendCmd(); });

// ===== SERVER ACTIONS =====
async function serverAction(action) {
  ['btnStart','btnStop','btnRestart'].forEach(id => { const el = document.getElementById(id); if(el) el.disabled = true; });
  const res  = await fetch(`/servers/${SERVER_ID}/${action}`, { method: 'POST' });
  const data = await res.json();
  if (data.success) setTimeout(() => location.reload(), 1000);
  else { alert('Action failed: ' + (data.message||'unknown')); setTimeout(() => location.reload(), 1000); }
}

// ===== STATS POLLING =====
async function pollStats() {
  try {
    const res  = await fetch(`/api/servers/${SERVER_ID}/stats`);
    const s    = await res.json();
    document.getElementById('statCpu').textContent = s.cpu + '%';
    document.getElementById('statMem').textContent = s.mem + 'MB / ' + s.memLimit + 'MB';
    document.getElementById('statStatus').textContent = (s.status||'unknown').toUpperCase();
    document.getElementById('cpuBar').style.width  = Math.min(s.cpu, 100) + '%';
    document.getElementById('memBar').style.width  = s.memPct + '%';
    const pill = document.getElementById('statusPill');
    if (pill) pill.className = 'status-pill status-' + s.status;
    document.getElementById('statusText').textContent = (s.status||'unknown').toUpperCase();
    document.getElementById('statusDot').className = 'status-dot-lg status-' + (s.status==='running'?'running':'offline');
    document.getElementById('statStatus').textContent = (s.status||'unknown').toUpperCase();
  } catch(e) {}
}

function copyAddr() {
  const addr = document.getElementById('serverAddr').textContent;
  navigator.clipboard.writeText(addr).then(() => {
    const card = document.querySelector('.addr-copy-card');
    card.style.opacity = '.5';
    setTimeout(() => card.style.opacity = '1', 800);
  });
}

// ===== FILE MANAGER =====
let currentPath = '/';
let editingPath  = null;

async function loadFiles(path) {
  currentPath = path || '/';
  document.getElementById('filesLoading').style.display = 'flex';
  document.getElementById('filesList').innerHTML = '';
  updateBreadcrumb(currentPath);
  try {
    const res  = await fetch(`/api/servers/${SERVER_ID}/files?path=${encodeURIComponent(currentPath)}`);
    const data = await res.json();
    document.getElementById('filesLoading').style.display = 'none';
    renderFiles(data.entries || []);
  } catch(e) {
    document.getElementById('filesLoading').innerHTML = '<p style="color:var(--red)">Failed to load files.</p>';
  }
}

function updateBreadcrumb(path) {
  const parts = path.split('/').filter(Boolean);
  let html = `<svg viewBox="0 0 24 24" style="width:13px;height:13px;flex-shrink:0"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
    <span class="bc-item" onclick="loadFiles('/')" style="cursor:pointer">root</span>`;
  let cum = '';
  for (const p of parts) {
    cum += '/' + p;
    const cp = cum;
    html += `<span class="bc-sep">/</span><span class="bc-item" onclick="loadFiles('${cp}')" style="cursor:pointer">${p}</span>`;
  }
  document.getElementById('fileBreadcrumb').innerHTML = html;
}

function renderFiles(entries) {
  if (!entries.length) {
    document.getElementById('filesList').innerHTML = '<div class="empty-state" style="padding:32px"><p>This folder is empty.</p></div>';
    return;
  }
  let html = '<table class="data-table files-table"><thead><tr><th width="36"></th><th>NAME</th><th>SIZE</th><th>MODIFIED</th><th>ACTIONS</th></tr></thead><tbody>';
  entries.forEach(e => {
    const icon = e.isDir
      ? `<svg class="icon-folder" viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>`
      : `<svg class="icon-file" viewBox="0 0 24 24"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>`;
    const size = e.isDir ? '—' : (e.size < 1024 ? e.size+'B' : e.size < 1048576 ? (e.size/1024).toFixed(1)+'KB' : (e.size/1048576).toFixed(1)+'MB');
    const modified = e.modified ? new Date(e.modified).toLocaleString() : '—';
    const nameCell = e.isDir
      ? `<span class="file-link dir-link" onclick="loadFiles('${e.path}')" style="cursor:pointer">${e.name}</span>`
      : `<span class="file-link">${e.name}</span>`;
    const editBtn = !e.isDir && isEditable(e.name)
      ? `<button class="btn btn-sm btn-ghost" onclick="openFileEdit('${e.path}','${e.name}')">EDIT</button>` : '';
    const dlBtn = !e.isDir
      ? `<a href="/servers/${SERVER_ID}/files/download?path=${encodeURIComponent(e.path)}" class="btn btn-sm btn-ghost">DL</a>` : '';
    const zipBtn = e.name.endsWith('.zip')
      ? `<button class="btn btn-sm btn-ghost" onclick="unzipFile('${e.path}')">UNZIP</button>` : '';
    const zipFolderBtn = e.isDir
      ? `<button class="btn btn-sm btn-ghost" onclick="zipFolder('${e.path}','${e.name}')">ZIP</button>` : '';
    html += `<tr>
      <td class="file-icon-cell">${icon}</td>
      <td>${nameCell}</td>
      <td class="file-size">${size}</td>
      <td class="file-size">${modified}</td>
      <td class="actions-cell">${editBtn}${dlBtn}${zipBtn}${zipFolderBtn}
        <button class="btn btn-sm btn-danger" onclick="deleteFile('${e.path}','${e.name}',${e.isDir})">DEL</button>
      </td>
    </tr>`;
  });
  html += '</tbody></table>';
  document.getElementById('filesList').innerHTML = html;
}

function isEditable(name) {
  const ext = name.split('.').pop().toLowerCase();
  return ['txt','json','yml','yaml','properties','cfg','conf','log','sh','env','toml','xml','js','ts','py','md','ini','htaccess','html','css'].includes(ext);
}

async function openFileEdit(path, name) {
  document.getElementById('fileEditTitle').textContent = 'EDIT — ' + name;
  document.getElementById('fileEditStatus').textContent = 'Loading...';
  document.getElementById('fileEditModal').style.display = 'flex';
  editingPath = path;
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/read?path=${encodeURIComponent(path)}`);
  const data = await res.json();
  const area = document.getElementById('fileEditArea');
  area.value = data.content || '';
  updateEditLineNums();
  document.getElementById('fileEditStatus').textContent = '';
}

function updateEditLineNums() {
  const area  = document.getElementById('fileEditArea');
  const nums  = document.getElementById('editLineNums');
  const lines = area.value.split('\n').length;
  nums.innerHTML = Array.from({ length: lines }, (_, i) => `<span>${i+1}</span>`).join('');
}

document.getElementById('fileEditArea').addEventListener('input', updateEditLineNums);
document.getElementById('fileEditArea').addEventListener('keydown', e => {
  if (e.key === 'Tab') { e.preventDefault(); const s = e.target.selectionStart; e.target.value = e.target.value.substring(0,s)+'  '+e.target.value.substring(e.target.selectionEnd); e.target.selectionStart = e.target.selectionEnd = s+2; }
  if (e.ctrlKey && e.key === 's') { e.preventDefault(); saveFileEdit(); }
  document.getElementById('fileEditArea').addEventListener('scroll', () => { document.getElementById('editLineNums').scrollTop = document.getElementById('fileEditArea').scrollTop; });
});

async function saveFileEdit() {
  document.getElementById('fileEditStatus').textContent = 'Saving...';
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/write`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: editingPath, content: document.getElementById('fileEditArea').value }),
  });
  const data = await res.json();
  document.getElementById('fileEditStatus').textContent = data.success ? 'Saved ✓' : 'Error: ' + data.message;
  document.getElementById('fileEditStatus').style.color = data.success ? 'var(--green)' : 'var(--red)';
}

function closeFileEdit() { document.getElementById('fileEditModal').style.display = 'none'; editingPath = null; }

async function deleteFile(path, name, isDir) {
  if (!confirm(`Delete "${name}"${isDir?' and all contents':''}?`)) return;
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/delete`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path }),
  });
  const data = await res.json();
  if (data.success) loadFiles(currentPath);
  else alert('Delete failed: ' + data.message);
}

async function createFolder() {
  const name = document.getElementById('newFolderName').value.trim();
  if (!name) return;
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/mkdir`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: currentPath, name }),
  });
  const data = await res.json();
  document.getElementById('newFolderModal').style.display = 'none';
  document.getElementById('newFolderName').value = '';
  if (data.success) loadFiles(currentPath);
}

async function createFile() {
  const name = document.getElementById('newFileName').value.trim();
  if (!name) return;
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/write`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: currentPath + '/' + name, content: '' }),
  });
  const data = await res.json();
  document.getElementById('newFileModal').style.display = 'none';
  document.getElementById('newFileName').value = '';
  if (data.success) loadFiles(currentPath);
}

async function unzipFile(path) {
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/unzip`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path }),
  });
  const data = await res.json();
  if (data.success) { loadFiles(currentPath); } else alert('Unzip failed: ' + data.message);
}

async function zipFolder(path, name) {
  const res  = await fetch(`/api/servers/${SERVER_ID}/files/zip`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path, name }),
  });
  const data = await res.json();
  if (data.success) loadFiles(currentPath); else alert('Zip failed: ' + data.message);
}

function showUploadModal()    { document.getElementById('uploadModal').style.display = 'flex'; }
function showNewFolderModal() { document.getElementById('newFolderModal').style.display = 'flex'; document.getElementById('newFolderName').focus(); }
function showNewFileModal()   { document.getElementById('newFileModal').style.display = 'flex'; document.getElementById('newFileName').focus(); }
function closeUploadModal()   { document.getElementById('uploadModal').style.display = 'none'; }

async function handleUpload() {
  const files    = document.getElementById('uploadInput').files;
  const progress = document.getElementById('uploadProgress');
  progress.innerHTML = '';
  for (const file of files) {
    const item = document.createElement('div');
    item.className = 'upload-item';
    item.textContent = `Uploading ${file.name}...`;
    progress.appendChild(item);
    const fd = new FormData();
    fd.append('path', currentPath);
    fd.append('file', file);
    try {
      const res  = await fetch(`/servers/${SERVER_ID}/files/upload`, { method: 'POST', body: fd });
      const data = await res.json();
      item.textContent  = data.success ? `✓ ${file.name}` : `✗ ${file.name}`;
      item.className    = 'upload-item ' + (data.success ? 'upload-ok' : 'upload-fail');
    } catch(e) { item.textContent = `✗ ${file.name}`; item.className = 'upload-item upload-fail'; }
  }
  setTimeout(() => { closeUploadModal(); loadFiles(currentPath); }, 1000);
}

// Drag drop on upload zone
const dz = document.getElementById('uploadDropZone');
if (dz) {
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
  dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('drag-over'); document.getElementById('uploadInput').files = e.dataTransfer.files; handleUpload(); });
}

// ===== SCHEDULES =====
async function loadSchedules() {
  const res  = await fetch(`/api/servers/${SERVER_ID}/schedules`);
  const data = await res.json();
  const el   = document.getElementById('schedulesList');
  if (!data.schedules || !data.schedules.length) {
    el.innerHTML = '<p class="muted-text">No schedules yet. Create one above.</p>'; return;
  }
  let html = '<table class="data-table"><thead><tr><th>NAME</th><th>CRON</th><th>ACTION</th><th>PAYLOAD</th><th>LAST RUN</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody>';
  data.schedules.forEach(s => {
    html += `<tr>
      <td><strong>${s.name}</strong></td>
      <td><code>${s.cron}</code></td>
      <td><span class="badge">${s.action}</span></td>
      <td><code>${s.payload||'—'}</code></td>
      <td class="file-size">${s.lastRun ? new Date(s.lastRun).toLocaleString() : 'Never'}</td>
      <td><button class="badge ${s.enabled?'badge-success':'badge-danger'}" style="border:none;cursor:pointer" onclick="toggleSchedule('${s._id}',this)">${s.enabled?'ACTIVE':'DISABLED'}</button></td>
      <td>
        <form method="POST" action="/servers/${SERVER_ID}/schedules/${s._id}/delete" style="display:inline" onsubmit="return confirm('Delete schedule?')">
          <button class="btn btn-sm btn-danger">DELETE</button>
        </form>
      </td>
    </tr>`;
  });
  html += '</tbody></table>';
  el.innerHTML = html;
}

async function toggleSchedule(id, btn) {
  const res  = await fetch(`/servers/${SERVER_ID}/schedules/${id}/toggle`, { method: 'POST' });
  const data = await res.json();
  if (data.success) { btn.textContent = data.enabled ? 'ACTIVE' : 'DISABLED'; btn.className = 'badge ' + (data.enabled ? 'badge-success' : 'badge-danger'); }
}

function togglePayload(sel) {
  document.getElementById('payloadGroup').style.display = sel.value === 'command' ? 'block' : 'none';
}

// ===== SUB-USERS =====
async function loadSubUsers() {
  const res  = await fetch(`/api/servers/${SERVER_ID}/subusers`);
  const data = await res.json();
  const el   = document.getElementById('subusersList');
  if (!data.subusers || !data.subusers.length) {
    el.innerHTML = '<p class="muted-text">No sub-users yet.</p>'; return;
  }
  let html = '<table class="data-table"><thead><tr><th>USER</th><th>EMAIL</th><th>PERMISSIONS</th><th>ACTIONS</th></tr></thead><tbody>';
  data.subusers.forEach(su => {
    const perms = (su.permissions || []).map(p => `<span class="badge" style="margin-right:3px">${p}</span>`).join('');
    html += `<tr>
      <td><strong>${su.userInfo ? su.userInfo.username : 'Unknown'}</strong></td>
      <td>${su.userInfo ? su.userInfo.email : '—'}</td>
      <td>${perms}</td>
      <td>
        <form method="POST" action="/servers/${SERVER_ID}/subusers/${su._id}/remove" style="display:inline" onsubmit="return confirm('Remove sub-user?')">
          <button class="btn btn-sm btn-danger">REMOVE</button>
        </form>
      </td>
    </tr>`;
  });
  html += '</tbody></table>';
  el.innerHTML = html;
}

async function addSubUser() {
  const email = document.getElementById('suEmail').value.trim();
  const perms = [...document.querySelectorAll('.su-perm:checked')].map(c => c.value);
  const res   = await fetch(`/servers/${SERVER_ID}/subusers/add`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, permissions: perms }),
  });
  const data  = await res.json();
  const resultEl = document.getElementById('suResult');
  resultEl.style.display = 'block';
  resultEl.className  = 'redeem-result ' + (data.success ? 'redeem-success' : 'redeem-error');
  resultEl.textContent = data.message;
  if (data.success) { document.getElementById('suEmail').value = ''; loadSubUsers(); }
}

// Init
connectWs();
pollStats();
setInterval(pollStats, 4000);
</script>

<% } %>