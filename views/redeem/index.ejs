<div class="redeem-page">
  <div class="redeem-hero">
    <div class="redeem-icon">
      <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
    </div>
    <h2 class="redeem-title">REDEEM CODE</h2>
    <p class="redeem-desc">Enter a coupon code below to claim KXY coins, extra RAM, Disk, CPU, or Server Slots. Each code can only be redeemed once per account.</p>
  </div>

  <div class="redeem-card">
    <div class="redeem-input-wrap">
      <input type="text" id="redeemInput" class="redeem-big-input" placeholder="ENTER-YOUR-CODE" autocomplete="off" spellcheck="false" />
      <button class="btn btn-primary btn-lg" id="redeemBtn" onclick="redeemCode()">
        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        REDEEM
      </button>
    </div>

    <div class="redeem-result-box" id="redeemResult" style="display:none">
      <div class="redeem-result-icon" id="redeemResultIcon"></div>
      <div class="redeem-result-text" id="redeemResultText"></div>
    </div>
  </div>

  <div class="redeem-stats">
    <div class="redeem-stat">
      <span class="redeem-stat-val"><%= kxy %></span>
      <span class="redeem-stat-label">CURRENT KXY</span>
    </div>
    <div class="redeem-stat">
      <span class="redeem-stat-val"><%= redeemedCount %></span>
      <span class="redeem-stat-label">CODES REDEEMED</span>
    </div>
  </div>

  <div class="redeem-what-box">
    <h3 class="redeem-what-title">WHAT CAN YOU GET?</h3>
    <div class="redeem-what-grid">
      <div class="redeem-what-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/></svg>
        <span>KXY Coins</span>
      </div>
      <div class="redeem-what-item">
        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>Extra RAM</span>
      </div>
      <div class="redeem-what-item">
        <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        <span>Extra Disk</span>
      </div>
      <div class="redeem-what-item">
        <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <span>Extra CPU</span>
      </div>
      <div class="redeem-what-item">
        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="5" rx="1"/><rect x="2" y="10" width="20" height="5" rx="1"/><rect x="2" y="17" width="20" height="5" rx="1"/></svg>
        <span>Server Slots</span>
      </div>
    </div>
    <p class="redeem-hint">Get codes from giveaways, promotions, or by asking an admin.</p>
  </div>
</div>

<script>
document.getElementById('redeemInput').addEventListener('input', function() {
  this.value = this.value.toUpperCase();
});
document.getElementById('redeemInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') redeemCode();
});

async function redeemCode() {
  const input   = document.getElementById('redeemInput');
  const btn     = document.getElementById('redeemBtn');
  const result  = document.getElementById('redeemResult');
  const icon    = document.getElementById('redeemResultIcon');
  const text    = document.getElementById('redeemResultText');
  const code    = input.value.trim();
  if (!code) return;

  btn.disabled = true;
  btn.textContent = 'CHECKING...';
  result.style.display = 'none';

  const res  = await fetch('/redeem/claim', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code }),
  });
  const data = await res.json();

  result.style.display = 'flex';
  result.className = 'redeem-result-box ' + (data.success ? 'result-success' : 'result-error');
  icon.innerHTML = data.success
    ? '<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>'
    : '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
  text.textContent = data.message;

  btn.disabled = false;
  btn.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> REDEEM';

  if (data.success) {
    input.value = '';
    const sidebarKxy = document.getElementById('sidebar-kxy');
    const topbarKxy  = document.getElementById('topbar-kxy-val');
    if (data.kxy !== undefined) {
      if (sidebarKxy) sidebarKxy.textContent = data.kxy;
      if (topbarKxy)  topbarKxy.textContent  = data.kxy;
      document.querySelector('.redeem-stat-val').textContent = data.kxy;
    }
    setTimeout(() => location.reload(), 2500);
  }
}
</script>
