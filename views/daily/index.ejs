<div class="daily-page">

  <!-- Hero -->
  <div class="daily-hero">
    <div class="daily-flame-wrap">
      <div class="daily-flame <%= streak >= 7 ? 'flame-hot' : streak >= 3 ? 'flame-warm' : '' %>" id="dailyFlame">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c0 0-6 5.686-6 10a6 6 0 0012 0C18 7.686 12 2 12 2zm0 15a3 3 0 01-3-3c0-2 3-6 3-6s3 4 3 6a3 3 0 01-3 3z"/></svg>
      </div>
      <div class="daily-streak-badge"><%= streak %></div>
    </div>
    <div class="daily-hero-text">
      <h2 class="daily-title">DAILY REWARD</h2>
      <p class="daily-subtitle">
        <% if (streak === 0) { %>
          Start your streak today!
        <% } else if (streak >= 30) { %>
          <span class="streak-max">MAX STREAK REACHED — 200 KXY/day!</span>
        <% } else { %>
          Day <strong><%= streak %></strong> streak · Keep it going!
        <% } %>
      </p>
    </div>
  </div>

  <!-- Claim card -->
  <div class="daily-claim-card">
    <div class="daily-claim-left">
      <div class="daily-today-reward">
        <span class="daily-today-label">TODAY'S REWARD</span>
        <span class="daily-today-amount">+<%= todayReward %> <span class="kxy-text">KXY</span></span>
        <span class="daily-today-day">Day <%= nextStreak %> of 30</span>
      </div>
    </div>
    <div class="daily-claim-right">
      <% if (canClaim) { %>
        <button class="btn btn-primary btn-claim" id="claimBtn" onclick="claimDaily()">
          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          CLAIM NOW
        </button>
      <% } else { %>
        <div class="daily-claimed-state">
          <div class="daily-claimed-check">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="daily-claimed-text">CLAIMED TODAY</div>
            <div class="daily-next-label">Next in <span id="dailyCountdown">--:--:--</span></div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Streak progress bar -->
  <div class="streak-progress-wrap">
    <div class="streak-progress-header">
      <span class="streak-progress-label">STREAK PROGRESS</span>
      <span class="streak-progress-count"><%= streak %> / 30 days</span>
    </div>
    <div class="streak-progress-bar">
      <div class="streak-progress-fill" style="width:<%= Math.min((streak / 30) * 100, 100).toFixed(1) %>%"></div>
      <!-- Milestone markers -->
      <div class="streak-milestone" style="left:23.3%" title="Day 7 — 62 KXY">7</div>
      <div class="streak-milestone" style="left:46.6%" title="Day 14 — 114 KXY">14</div>
      <div class="streak-milestone" style="left:66.6%" title="Day 20 — 152 KXY">20</div>
      <div class="streak-milestone" style="left:99%" title="Day 30 — 200 KXY MAX">30</div>
    </div>
    <div class="streak-milestones-labels">
      <span>Day 1 · 10 KXY</span>
      <span>Day 7 · 62 KXY</span>
      <span>Day 14 · 114 KXY</span>
      <span>Day 30 · 200 KXY MAX</span>
    </div>
  </div>

  <!-- 30-day calendar grid -->
  <div class="panel">
    <div class="panel-header">
      <h2 class="panel-title">30-DAY CALENDAR</h2>
      <span class="panel-subtitle muted-text">Claim every day to maximize rewards. Missing a day resets your streak.</span>
    </div>
    <div class="panel-body">
      <div class="daily-calendar">
        <% calendar.forEach(d => { %>
        <div class="cal-day
          <%= d.claimed ? 'cal-claimed' : '' %>
          <%= d.today   ? 'cal-today'   : '' %>
          <%= d.locked  ? 'cal-locked'  : '' %>
          <%= d.day === 30 ? 'cal-max' : '' %>
        ">
          <div class="cal-day-num"><%= d.day %></div>
          <div class="cal-day-icon">
            <% if (d.claimed) { %>
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            <% } else if (d.today) { %>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/></svg>
            <% } else if (d.day === 30) { %>
              <svg viewBox="0 0 24 24"><path d="M12 2c0 0-6 5.686-6 10a6 6 0 0012 0C18 7.686 12 2 12 2z" fill="currentColor"/></svg>
            <% } else { %>
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/></svg>
            <% } %>
          </div>
          <div class="cal-day-reward">+<%= d.reward %></div>
          <div class="cal-day-kxy">KXY</div>
          <% if (d.day === 30) { %><div class="cal-max-badge">MAX</div><% } %>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Streak info -->
  <div class="streak-info-row">
    <div class="streak-info-card">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div>
        <strong>How streaks work</strong>
        <p>Claim once per day. Each consecutive day increases your reward. Miss a day and your streak resets to Day 1. Reach Day 30 for the maximum reward of <strong>200 KXY/day</strong> — it stays at 200 KXY from then on.</p>
      </div>
    </div>
  </div>

</div>

<!-- Claim success overlay -->
<div class="claim-overlay" id="claimOverlay" style="display:none">
  <div class="claim-overlay-card">
    <div class="claim-overlay-icon">🎉</div>
    <div class="claim-overlay-amount" id="overlayAmount"></div>
    <div class="claim-overlay-msg" id="overlayMsg"></div>
    <div class="claim-overlay-streak" id="overlayStreak"></div>
  </div>
</div>

<script>
// Countdown to midnight UTC
<% if (!canClaim) { %>
let msLeft = <%= nextRewardMs %>;
const cdEl = document.getElementById('dailyCountdown');
function tickDaily() {
  if (msLeft <= 0) { location.reload(); return; }
  const h = Math.floor(msLeft / 3600000);
  const m = Math.floor((msLeft % 3600000) / 60000);
  const s = Math.floor((msLeft % 60000) / 1000);
  if (cdEl) cdEl.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  msLeft -= 1000;
}
tickDaily(); setInterval(tickDaily, 1000);
<% } %>

async function claimDaily() {
  const btn = document.getElementById('claimBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> CLAIMING...';

  try {
    const res  = await fetch('/daily/claim', { method: 'POST' });
    const data = await res.json();

    if (data.success) {
      // Update KXY displays
      ['sidebar-kxy','topbar-kxy-val'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = data.kxy;
      });

      // Show overlay
      const overlay = document.getElementById('claimOverlay');
      document.getElementById('overlayAmount').textContent = `+${data.reward} KXY`;
      document.getElementById('overlayMsg').textContent    = data.message;
      document.getElementById('overlayStreak').textContent = `Day ${data.streak} streak!`;
      overlay.style.display = 'flex';

      setTimeout(() => {
        overlay.style.display = 'none';
        location.reload();
      }, 2500);
    } else {
      btn.disabled = false;
      btn.innerHTML = data.message;
      setTimeout(() => location.reload(), 1500);
    }
  } catch(e) {
    btn.disabled = false;
    btn.textContent = 'ERROR — try again';
  }
}
</script>
